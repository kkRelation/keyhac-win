+_user32 = ctypes.windll.user32
+_user32.GetAsyncKeyState.argtypes = [ctypes.c_int]
+_user32.GetAsyncKeyState.restype = ctypes.c_short
+_WIN_VKS = (0x5B, 0x5C, 235, 255)
+
+
+def _is_any_win_key_down():
+    return any((_user32.GetAsyncKeyState(vk) & 0x8000) != 0 for vk in _WIN_VKS)
+
+def register_win_a_clipboard_passthrough(keymap, keymap_global):
+    pending_win_a = [False]
+    polling_win_a = [False]
+    run_alt_l = make_copy_selection_before_passthrough_command(
+        keymap,
+        "A-L",
+        initial_delay_ms=30,
+    )
+
+    def run_when_win_released(attempt=0):
+        if not pending_win_a[0]:
+            polling_win_a[0] = False
+            return
+
+        if not _is_any_win_key_down():
+            pending_win_a[0] = False
+            polling_win_a[0] = False
+            run_alt_l()
+            return
+
+        if attempt >= 250:
+            pending_win_a[0] = False
+            polling_win_a[0] = False
+            return
+
+        keymap.delayedCall(lambda: run_when_win_released(attempt + 1), 20)
+
+    def mark_win_a():
+        pending_win_a[0] = True
+        if polling_win_a[0]:
+            return
+        polling_win_a[0] = True
+        keymap.delayedCall(run_when_win_released, 20)
+
+    keymap_global["D-U0-A"] = mark_win_a
+    keymap_global["U0-A"] = mark_win_a
+
 
