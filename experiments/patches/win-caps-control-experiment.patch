+    ctypes.c_wchar_p,
+]
+gdi32.CreateFontW.restype = ctypes.c_void_p
+kernel32.GetModuleHandleW.argtypes = [ctypes.c_wchar_p]
+kernel32.GetModuleHandleW.restype = ctypes.c_void_p
+
+
+WM_DESTROY = 0x0002
+WM_PAINT = 0x000F
+WM_TIMER = 0x0113
+
+WS_POPUP = 0x80000000
+WS_VISIBLE = 0x10000000
+
+WS_EX_LAYERED = 0x00080000
+WS_EX_TRANSPARENT = 0x00000020
+WS_EX_TOOLWINDOW = 0x00000080
+WS_EX_TOPMOST = 0x00000008
+
+SW_SHOWNOACTIVATE = 4
+LWA_COLORKEY = 0x00000001
+DT_CENTER = 0x00000001
+DT_VCENTER = 0x00000004
+DT_SINGLELINE = 0x00000020
+TRANSPARENT = 1
+BLACK_BRUSH = 4
+DEFAULT_CHARSET = 1
+OUT_DEFAULT_PRECIS = 0
+CLIP_DEFAULT_PRECIS = 0
+ANTIALIASED_QUALITY = 4
+DEFAULT_PITCH = 0
+FF_DONTCARE = 0
+
+
+class WNDCLASSW(ctypes.Structure):
+    _fields_ = [
+        ("style", ctypes.c_uint),
+        ("lpfnWndProc", ctypes.c_void_p),
+        ("cbClsExtra", ctypes.c_int),
+        ("cbWndExtra", ctypes.c_int),
+        ("hInstance", ctypes.c_void_p),
+        ("hIcon", ctypes.c_void_p),
+        ("hCursor", ctypes.c_void_p),
+        ("hbrBackground", ctypes.c_void_p),
+        ("lpszMenuName", ctypes.c_wchar_p),
+        ("lpszClassName", ctypes.c_wchar_p),
+    ]
+
+
+class POINT(ctypes.Structure):
+    _fields_ = [("x", ctypes.c_long), ("y", ctypes.c_long)]
+
+
+class MSG(ctypes.Structure):
+    _fields_ = [
+        ("hwnd", ctypes.c_void_p),
+        ("message", ctypes.c_uint),
+        ("wParam", ctypes.c_size_t),
+        ("lParam", ctypes.c_ssize_t),
+        ("time", ctypes.c_uint),
+        ("pt", POINT),
+    ]
+
+
+class RECT(ctypes.Structure):
+    _fields_ = [
+        ("left", ctypes.c_long),
+        ("top", ctypes.c_long),
+        ("right", ctypes.c_long),
+        ("bottom", ctypes.c_long),
+    ]
+
+
+class PAINTSTRUCT(ctypes.Structure):
+    _fields_ = [
+        ("hdc", ctypes.c_void_p),
+        ("fErase", ctypes.c_int),
+        ("rcPaint", RECT),
+        ("fRestore", ctypes.c_int),
+        ("fIncUpdate", ctypes.c_int),
+        ("rgbReserved", ctypes.c_byte * 32),
+    ]
+
+
+_active_overlays = {}
+_overlay_lock = threading.Lock()
+_class_atom = None
+_wnd_proc = None
+_class_name = "CodexOverlayTextWindow"
+
+
+def _register_window_class():
+    global _class_atom, _wnd_proc
+
+    if _class_atom is not None:
+        return
+
+    _wnd_proc = WNDPROC(_overlay_wnd_proc)
+
+    wc = WNDCLASSW()
+    wc.lpfnWndProc = ctypes.cast(_wnd_proc, ctypes.c_void_p).value
+    wc.hInstance = kernel32.GetModuleHandleW(None)
+    wc.hbrBackground = gdi32.GetStockObject(BLACK_BRUSH)
+    wc.lpszClassName = _class_name
+    _class_atom = user32.RegisterClassW(ctypes.byref(wc))
+
+
+def _overlay_wnd_proc(hwnd, msg, wparam, lparam):
+    if msg == WM_PAINT:
+        overlay = _active_overlays.get(hwnd)
+        if overlay is not None:
+            ps = PAINTSTRUCT()
+            hdc = user32.BeginPaint(hwnd, ctypes.byref(ps))
+            rect = RECT()
+            user32.GetClientRect(hwnd, ctypes.byref(rect))
+            brush = gdi32.GetStockObject(BLACK_BRUSH)
+            user32.FillRect(hdc, ctypes.byref(rect), brush)
+
+            gdi32.SetBkMode(hdc, TRANSPARENT)
+            gdi32.SetTextColor(hdc, 0x00FFFFFF)
+            old_font = gdi32.SelectObject(hdc, overlay["font"])
+            user32.DrawTextW(
+                hdc,
+                overlay["text"],
+                -1,
+                ctypes.byref(rect),
+                DT_CENTER | DT_VCENTER | DT_SINGLELINE,
+            )
+            gdi32.SelectObject(hdc, old_font)
+            user32.EndPaint(hwnd, ctypes.byref(ps))
+        return 0
+
+    if msg == WM_TIMER:
+        user32.DestroyWindow(hwnd)
+        return 0
+
+    if msg == WM_DESTROY:
+        overlay = _active_overlays.pop(hwnd, None)
+        if overlay is not None:
+            gdi32.DeleteObject(overlay["font"])
+        user32.PostQuitMessage(0)
+        return 0
+
+    return user32.DefWindowProcW(hwnd, msg, wparam, lparam)
+
+
+def _show_overlay_window(text, timeout_ms, font_height):
+    _register_window_class()
+
+    screen_w = user32.GetSystemMetrics(0)
+    screen_h = user32.GetSystemMetrics(1)
+    width = max(220, len(text) * max(font_height // 2, 12))
+    height = max(font_height * 2, 72)
+    left = max((screen_w - width) // 2, 0)
+    top = max(int(screen_h * 0.18), 0)
+
+    hwnd = user32.CreateWindowExW(
+        WS_EX_LAYERED | WS_EX_TRANSPARENT | WS_EX_TOOLWINDOW | WS_EX_TOPMOST,
+        _class_name,
+        None,
+        WS_POPUP | WS_VISIBLE,
+        left,
+        top,
+        width,
+        height,
+        None,
+        None,
+        kernel32.GetModuleHandleW(None),
+        None,
+    )
+
+    if not hwnd:
+        return
+
+    font = gdi32.CreateFontW(
+        font_height,
+        0,
+        0,
+        0,
+        700,
+        0,
+        0,
+        0,
+        DEFAULT_CHARSET,
+        OUT_DEFAULT_PRECIS,
+        CLIP_DEFAULT_PRECIS,
+        ANTIALIASED_QUALITY,
+        DEFAULT_PITCH | FF_DONTCARE,
+        "Inconsolata-LXGWMono",
+    )
+
+    with _overlay_lock:
+        _active_overlays[hwnd] = {
+            "text": text,
+            "font": font,
+        }
+
+    user32.SetLayeredWindowAttributes(hwnd, 0x00000000, 0, LWA_COLORKEY)
+    user32.ShowWindow(hwnd, SW_SHOWNOACTIVATE)
+    user32.UpdateWindow(hwnd)
+    user32.SetTimer(hwnd, 1, timeout_ms, None)
+
+    msg = MSG()
+    while user32.GetMessageW(ctypes.byref(msg), None, 0, 0) > 0:
+        user32.TranslateMessage(ctypes.byref(msg))
+        user32.DispatchMessageW(ctypes.byref(msg))
+
+
+def show_text(text, timeout_ms=900, font_height=32):
+    thread = threading.Thread(
+        target=_show_overlay_window,
+        args=(text, timeout_ms, font_height),
+        daemon=True,
+    )
+    thread.start()
