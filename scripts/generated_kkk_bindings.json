{
  "meta": {
    "name": "kanata-keyhac-komorebi",
    "version": 1,
    "philosophy": [
      "Kanata owns physical-key interception and multi-mod combos.",
      "Keyhac owns Python workflows, state, and non-trivial UI/script logic.",
      "Komorebi owns final window-manager side effects and bar visibility state."
    ]
  },
  "modifier_exports": [
    {
      "id": "u0",
      "physical_key": "lmet",
      "kanata_output": "f19",
      "keyhac_user_modifier": "U0",
      "kanata_hold_layer": "win-layer"
    },
    {
      "id": "u1",
      "physical_key": "caps",
      "kanata_output": "f20",
      "keyhac_user_modifier": "U1",
      "kanata_hold_layer": null
    },
    {
      "id": "u2",
      "physical_key": "ralt",
      "kanata_output": "f21",
      "keyhac_user_modifier": "U2",
      "kanata_hold_layer": null
    },
    {
      "id": "u3",
      "physical_key": "rctrl",
      "kanata_output": "f22",
      "keyhac_user_modifier": "U3",
      "kanata_hold_layer": null
    },
    {
      "id": "u4",
      "physical_key": "rshift",
      "kanata_output": "f23",
      "keyhac_user_modifier": "U4",
      "kanata_hold_layer": null
    }
  ],
  "state_sync": [
    {
      "id": "komorebi_modal_sync",
      "source": "kanata",
      "transport": "kanata_layer_switch_plus_state_client",
      "helper": {
        "type": "native_exe",
        "path": "D:\\C2D\\Desktop\\Code\\Python\\automation\\state_center\\target\\release\\state-client.exe"
      },
      "state": {
        "base": false,
        "modal": true
      }
    }
  ],
  "kanata_direct_commands": [
    {
      "id": "km_toggle_modal",
      "layer": "global",
      "key": "lctrl+caps",
      "action": {
        "type": "kanata_layer_toggle",
        "target_layers": [
          "base",
          "modal"
        ]
      }
    },
    {
      "id": "km_focus_left",
      "layer": "modal",
      "key": "h",
      "action": {
        "type": "komorebic",
        "args": [
          "focus",
          "left"
        ]
      }
    },
    {
      "id": "km_focus_down",
      "layer": "modal",
      "key": "j",
      "action": {
        "type": "komorebic",
        "args": [
          "focus",
          "down"
        ]
      }
    },
    {
      "id": "km_focus_up",
      "layer": "modal",
      "key": "k",
      "action": {
        "type": "komorebic",
        "args": [
          "focus",
          "up"
        ]
      }
    },
    {
      "id": "km_focus_right",
      "layer": "modal",
      "key": "l",
      "action": {
        "type": "komorebic",
        "args": [
          "focus",
          "right"
        ]
      }
    },
    {
      "id": "km_core_caps_actions",
      "layer": "base",
      "key": "caps+{h,j,k,l,q,m,i,t,p,x,y,g,arrows,[,],',',.,-,=,1..9}",
      "action": {
        "type": "komorebic_group",
        "note": "Pure U1-* window-management bindings are Kanata-owned."
      }
    },
    {
      "id": "km_core_alt_caps_actions",
      "layer": "alt-layer",
      "key": "alt+caps+{h,j,k,l,o,g,[,],enter,.,-,=,f,r,1..9}",
      "action": {
        "type": "komorebic_group",
        "note": "Pure A-U1-* window-management bindings are Kanata-owned."
      }
    },
    {
      "id": "km_core_modal_shift_actions",
      "layer": "shift-layer",
      "key": "modal+shift+{h,j,k,l,enter,o,-,=,1..9}",
      "action": {
        "type": "komorebic_group",
        "note": "Pure D-S-* modal window-management bindings are Kanata-owned."
      }
    }
  ],
  "combo_intercepts": [
    {
      "id": "bar_toggle_0",
      "mods": [
        "u1",
        "u2"
      ],
      "physical_mods": [
        "caps",
        "ralt"
      ],
      "key": "0",
      "backend": "kanata_cmd",
      "action": {
        "type": "native_exe",
        "path": "D:\\C2D\\Desktop\\Code\\Python\\automation\\kanata_config\\tools\\komorebi-bar-toggle\\target\\release\\komorebi-bar-toggle.exe",
        "args": [
          "0"
        ]
      },
      "layers": {
        "base": {
          "fallback": "0"
        },
        "modal": {
          "fallback": "0"
        },
        "alt-layer": {
          "fallback": "0"
        },
        "win-layer": {
          "fallback": "0"
        },
        "shift-layer": {
          "fallback": "0"
        }
      }
    },
    {
      "id": "bar_toggle_1",
      "mods": [
        "u1",
        "u2"
      ],
      "physical_mods": [
        "caps",
        "ralt"
      ],
      "key": "1",
      "backend": "kanata_cmd",
      "action": {
        "type": "native_exe",
        "path": "D:\\C2D\\Desktop\\Code\\Python\\automation\\kanata_config\\tools\\komorebi-bar-toggle\\target\\release\\komorebi-bar-toggle.exe",
        "args": [
          "1"
        ]
      },
      "layers": {
        "base": {
          "fallback": "1"
        },
        "modal": {
          "fallback": "@k-ws-1"
        },
        "alt-layer": {
          "fallback": "1"
        },
        "win-layer": {
          "fallback": "1"
        },
        "shift-layer": {
          "fallback_when_base_layer_modal": "@k-move-ws-1",
          "fallback_else": "S-1"
        }
      }
    }
  ],
  "runtime_defaults": {
    "komorebi_hotkey_backend": "kanata",
    "ownership_note": "Kanata owns simple komorebi chords and direct commands; Keyhac owns Python/UI/stateful workflows."
  },
  "future_patterns": [
    {
      "id": "triple_user_combo",
      "example": {
        "mods": [
          "u3",
          "u4",
          "u5"
        ],
        "key": "b",
        "backend": "kanata_signal_to_keyhac"
      },
      "note": "Treat multi-user printable combos as Kanata-owned intercepts. Keyhac should receive a stable signal instead of re-detecting the combo."
    }
  ]
}